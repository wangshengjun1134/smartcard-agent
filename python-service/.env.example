# Coding Plan API Configuration (阿里云百炼 Coding Plan)
BAILIAN_CODING_PLAN_API_KEY=sk-sp-your-coding-plan-key-here
OPENAI_API_BASE=https://coding.dashscope.aliyuncs.com/v1
OPENAI_MODEL=qwen3.5-plus

# 标准 DashScope API Configuration (可选，用于云端 Embeddings)
# 注意：Coding Plan API Key 不支持 Embeddings API
# 如果不配置，将自动使用本地 BGE-m3 模型
DASHSCOPE_API_KEY=
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# 本地 Embeddings 配置 (BGE-m3)
USE_LOCAL_EMBEDDINGS=true
LOCAL_EMBEDDING_PATH=data/models/bge-m3
EMBEDDING_DEVICE=cpu

# Qdrant Vector Database Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=knowledge_base
QDRANT_PREFER_GRPC=false
QDRANT_IN_MEMORY=true
QDRANT_LOCAL_PATH=

# Local LLM Configuration (可选，用于离线模式)
USE_LOCAL_LLM=false
LOCAL_LLM_PATH=