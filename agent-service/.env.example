# Agent Service Configuration

# LLM Configuration (for agent reasoning)
LLM_API_KEY=sk-sp-xxx
LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
LLM_MODEL_NAME=qwen3.5-plus
LLM_TEMPERATURE=0.7

# Alternative local LLM (Ollama)
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen2.5:7b

# Runtime State
CHECKPOINT_PATH=./data/checkpoints
CHECKPOINT_MAX_COUNT=10

# PCSC Configuration
PCSC_READER_INDEX=0
PCSC_MAX_RETRIES=3
PCSC_RETRY_DELAY=0.5
PCSC_TIMEOUT=30.0

# Agent Configuration
AGENT_MAX_ITERATIONS=20
AGENT_TIMEOUT=120.0
AGENT_MAX_TURNS=15
AGENT_MAX_TIME_MINUTES=10.0

# Session Database
SESSION_DB_PATH=./data/session.db

# Skills Directory
SKILLS_DIR=./.skills

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001
API_DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s %(levelname)s %(name)s: %(message)s