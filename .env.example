# SmartcardAgent 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=SmartcardAgent
APP_VERSION=0.1.0

# Python 服务配置 (已拆分为两个独立服务)
# Agent 服务 - 智能卡操作 Agent (默认端口 8001)
VITE_AGENT_BASE_URL=http://localhost:8001
# RAG 服务 - 知识库与向量检索 (默认端口 8002，可远程部署)
VITE_RAG_BASE_URL=http://localhost:8002

# Tauri 配置
TAURI_DEV_PORT=1420

# 日志配置
LOG_LEVEL=info